@model RazorProject.Front.ViewModels.ChamadoDetailsViewModel

@{
    ViewData["Title"] = "Excluir chamado";
}

<h1>Excluir chamado</h1>

<p>Tem certeza que deseja excluir este chamado?</p>

<dl class="row">
    <dt class="col-sm-3">Titulo</dt>
    <dd class="col-sm-9">@Model.Titulo</dd>

    <dt class="col-sm-3">Categoria</dt>
    <dd class="col-sm-9">@Model.Categoria</dd>

    <dt class="col-sm-3">Prioridade</dt>
    <dd class="col-sm-9">@Model.Prioridade</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
