@model RazorProject.Front.ViewModels.ChamadoDetailsViewModel

@{
    ViewData["Title"] = "Detalhes do chamado";
}

<h1>Detalhes do chamado</h1>

<dl class="row">
    <dt class="col-sm-3">Titulo</dt>
    <dd class="col-sm-9">@Model.Titulo</dd>

    <dt class="col-sm-3">Descricao</dt>
    <dd class="col-sm-9">@Model.Descricao</dd>

    <dt class="col-sm-3">Categoria</dt>
    <dd class="col-sm-9">@Model.Categoria</dd>

    <dt class="col-sm-3">Prioridade</dt>
    <dd class="col-sm-9">@Model.Prioridade</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Data abertura</dt>
    <dd class="col-sm-9">@Model.DataAbertura.ToString("dd/MM/yyyy HH:mm")</dd>

    <dt class="col-sm-3">Data finalizacao</dt>
    <dd class="col-sm-9">@(Model.DataFinalizacao?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

    <dt class="col-sm-3">Solicitante</dt>
    <dd class="col-sm-9">@Model.Solicitante</dd>

    <dt class="col-sm-3">Responsavel</dt>
    <dd class="col-sm-9">@Model.Responsavel</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Voltar</a>
